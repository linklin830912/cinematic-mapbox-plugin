{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",

    "rootDir": "./src",
    "outDir": "./dist",

    "lib": ["DOM", "ESNext"],

    "strict": true,
    "declaration": true,

    "moduleResolution": "Bundler",

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  
  "include": [
    "src", 
    "dev",
    "index.ts", 
    "vite-env.d.ts"
  ]
}